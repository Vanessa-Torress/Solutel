<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Prevent rewriting for API calls so they are handled directly (if applicable)
  RewriteCond %{REQUEST_URI} ^/api/ [NC]
  RewriteRule ^ - [L]

  # Rules for React Router SPA (Single Page Application)
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>
